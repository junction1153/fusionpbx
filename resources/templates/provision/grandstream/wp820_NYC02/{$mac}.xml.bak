<!-- # Use First Matching Vocoder in 200OK SDP. 0 - No, 1 - Yes. Default is 0 -->
<!-- # Number: 0, 1 -->
<!-- # Mandatory -->
<P2348>0</P2348>

<!-- # OPUS Payload Type. Default is 123 -->
<!-- # Number: 96 - 127 -->
<!-- # Mandatory -->
<P2385>123</P2385>

<!-- # Send DTMF: In-audio. 0 - No, 1 - Yes. Default is 0 -->
<!-- # Number: 0, 1 -->
<!-- # Mandatory -->
<P2301>0</P2301>

<!-- # Send DTMF: Via RTP (RFC2833). 0 - No, 1 - Yes. Default is 1 -->
<!-- # Number: 0, 1 -->
<!-- # Mandatory -->
