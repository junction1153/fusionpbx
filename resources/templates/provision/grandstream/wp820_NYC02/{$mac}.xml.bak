<!-- # Local SIP Port. Default is 5060 -->
<!-- # Number -->
<!-- # Mandatory -->
<P413>5060</P413>

<!-- # SIP URI Scheme when using TLS. 0 - sip, 1 - sips. Default is 1 -->
<!-- # Number: 0, 1 -->
<!-- # Mandatory -->
<P2429>1</P2429>

<!-- # Session Timer -->
<!-- # Enable Session Timer. 0 - No, 1 - Yes. Default is 1 -->
<!-- # Number: 0, 1 -->
<!-- # Mandatory -->
<P2395>0</P2395>

